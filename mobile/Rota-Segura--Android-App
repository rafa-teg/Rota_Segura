import android.Manifest
import androidx.activity.compose.rememberLauncherForActivityResult
import androidx.activity.result.contract.ActivityResultContracts
import androidx.compose.material3.Button
import androidx.compose.material3.Text
import androidx.compose.runtime.*
import androidx.compose.ui.platform.LocalContext

@Composable
fun LocationPermissionRequester(onPermissionGranted: () -> Unit) {
    // Contexto local para acessar recursos do sistema
    val context = LocalContext.current

    // Estado para controlar se a permissão foi concedida
    var permissionState by remember { mutableStateOf(false) }

    // Inicialize o launcher para solicitar permissão
    val requestPermissionLauncher = rememberLauncherForActivityResult(
        contract = ActivityResultContracts.RequestPermission(),
        onResult = { isGranted: Boolean ->
            permissionState = isGranted
        }
    )

    // Efeito lateral para executar a ação quando a permissão for concedida
    LaunchedEffect(permissionState) {
        if (permissionState) {
            onPermissionGranted()
        }
    }

    // Botão que, quando clicado, solicita a permissão de localização
    Button(onClick = { requestPermissionLauncher.launch(Manifest.permission.ACCESS_FINE_LOCATION) }) {
        Text("Solicitar Permissão de Localização")
    }

    // Feedback para o usuário sobre o estado da permissão
    if (permissionState) {
        Text("Permissão concedida")
    } else {
        Text("Permissão necessária para acessar a localização")
    }
}


