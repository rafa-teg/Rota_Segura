import com.google.android.gms.location.FusedLocationProviderClient
import com.google.android.gms.location.LocationRequest
import com.google.android.gms.location.LocationServices
import com.google.android.gms.tasks.CancellationTokenSource

@SuppressLint("MissingPermission") // Garante que a permissão já foi concedida neste ponto
@Composable
fun FetchUserLocation(onLocationObtained: (Location) -> Unit) {
    val context = LocalContext.current
    var location by remember {
        mutableStateOf<Location?>(null)
    }

    // Cria uma instância do FusedLocationProviderClient
    val fusedLocationClient: FusedLocationProviderClient = LocationServices.getFusedLocationProviderClient(context)

    // Utilize LaunchedEffect para executar a busca pela localização atual
    LaunchedEffect(key1 = true) {
        val cancellationTokenSource = CancellationTokenSource()

        // Obtém a última localização conhecida
        fusedLocationClient.getCurrentLocation(
            com.google.android.gms.location.LocationRequest.PRIORITY_HIGH_ACCURACY,
            cancellationTokenSource.token
        ).addOnSuccessListener { loc: Location? ->
            loc?.let {
                location = it
                onLocationObtained(it) // Chama o callback com a localização
            }
        }.addOnFailureListener {
            // Trate o caso de falha ao obter a localização
        }
    }

    // Opcional: Mostra a localização atual na UI ou utiliza como necessário
    location?.let {
        // Faça algo com a localização, por exemplo, atualizar a UI
    }
}
